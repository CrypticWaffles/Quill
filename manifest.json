{
  "manifest_version": 3,
  "name": "Quill",
  "version": "1.0.0",
  "description": "Real-time grammar and spelling checker powered by LanguageTool or Claude AI — by Quill",
  "permissions": ["storage"],
  "host_permissions": [
    "https://api.languagetool.org/*",
    "https://api.anthropic.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Quill"
  }
}
